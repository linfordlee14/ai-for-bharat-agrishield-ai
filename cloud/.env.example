# AWS Configuration (Lambda + API Gateway only)
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1

# Environment (dev, staging, prod)
ENVIRONMENT=dev

# PostgreSQL on VPS (replaces DynamoDB)
DATABASE_URL=postgresql://postgres:password@YOUR_VPS_IP:5432/forest_db

# Alert Configuration
ALERT_PHONE_NUMBERS=+1234567890,+0987654321

# Frontend Configuration (for production deployment)
FRONTEND_DOMAIN=dashboard.agrishield.example.com
CERTIFICATE_ARN=arn:aws:acm:us-east-1:123456789012:certificate/xxxxx

# Optional: Custom VPC Configuration
# VPC_ID=vpc-xxxxx
# PRIVATE_SUBNET_IDS=subnet-xxxxx,subnet-yyyyy
