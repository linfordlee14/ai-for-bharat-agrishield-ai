{
  "name": "agrishield-cloud",
  "version": "1.0.0",
  "description": "AgriShield AI Cloud Infrastructure",
  "main": "bin/app.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "deploy": "cdk deploy --all",
    "deploy:dev": "cdk deploy --all --context environment=dev",
    "deploy:staging": "cdk deploy --all --context environment=staging",
    "deploy:prod": "cdk deploy --all --context environment=prod --require-approval broadening",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "destroy": "cdk destroy --all"
  },
  "keywords": [
    "agrishield",
    "wildlife",
    "iot",
    "aws",
    "cdk"
  ],
  "author": "AgriShield AI",
  "license": "PROPRIETARY",
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "aws-cdk": "^2.117.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.117.0",
    "constructs": "^10.3.0",
    "dotenv": "^16.3.1"
  }
}
